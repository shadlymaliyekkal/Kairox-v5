        for l in lines1:
            self._parse_nuclei_line(l)
        prog.log(f"  [bold {GREEN}]nuclei[/] phase 1 done ({len([l for l in lines1 if l.startswith('[')])} hits)")

        # ── Phase 2: default-login checks (fast, low volume) ──────────────────
        prog.log(f"  [bold {C2}]nuclei[/] phase 2/3 — default logins ...")
        ok2, lines2 = NucleiGuard.run_phase(
            self.base_url,
            tags="default-login",
            severity="critical,high",
            wall_timeout=60,
        )
        for l in lines2:
            self._parse_nuclei_line(l)
        prog.log(f"  [bold {GREEN}]nuclei[/] phase 2 done ({len([l for l in lines2 if l.startswith('[')])} hits)")

        # ── Phase 3: CVE templates (heaviest — tightest guard) ────────────────
        prog.log(f"  [bold {C2}]nuclei[/] phase 3/3 — CVEs [concurrency=3, rate=5] ...")
        # Override to minimum safe values for CVE phase
        saved_c = NucleiGuard.CONCURRENCY
        saved_r = NucleiGuard.RATE_LIMIT
        saved_b = NucleiGuard.BULK_SIZE
        NucleiGuard.CONCURRENCY = 3
        NucleiGuard.RATE_LIMIT  = 5
        NucleiGuard.BULK_SIZE   = 3
        ok3, lines3 = NucleiGuard.run_phase(
            self.base_url,
            tags="cve",
            severity="critical,high",
            wall_timeout=90,
        )
        NucleiGuard.CONCURRENCY = saved_c
        NucleiGuard.RATE_LIMIT  = saved_r
        NucleiGuard.BULK_SIZE   = saved_b
        for l in lines3:
            self._parse_nuclei_line(l)
        prog.log(f"  [bold {GREEN}]nuclei[/] phase 3 done ({len([l for l in lines3 if l.startswith('[')])} hits)")

    def _parse_nuclei_line(self, line):
        # Skip internal guard messages and empty lines
        if not line or line.startswith('[kx-guard]') or not line.startswith('['):
            return
        m = re.search(r"\[(critical|high|medium|low|info)\]", line, re.I)
        if not m:
            return  # not a nuclei finding line
        sev = m.group(1).upper()
        entry = line.strip()
        self.results["vulns"].append({"sev": sev, "desc": entry, "source": "nuclei"})
        self._add(sev, "nuclei", entry)

    # ── 14. Nikto Web Scan ────────────────────────────────────────────────────
    def run_nikto(self, prog):
        if not tool_ok("nikto"):
            prog.log(f"  [bold {ORNG}]nikto[/] not installed — skipping")
            return
        prog.log(f"  [bold {C2}]nikto[/] → web vulnerability scan ...")
        ok, out = run_cmd(["nikto", "-host", self.base_url, "-nointeractive",
                           "-maxtime", "90", "-Format", "txt", "-Tuning", "023479abc"], 120)
        if ok:
            for l in lns(out):
                if l.startswith("+"):
                    entry = l.lstrip("+ ").strip()
                    sev = "CRITICAL" if re.search(r"remote code|rce|inject.*exec", entry, re.I) else \
                          "HIGH" if re.search(r"critical|sql|traversal|lfi|rfi|file read", entry, re.I) else "MEDIUM"
                    self.results["vulns"].append({"sev":sev,"desc":entry,"source":"nikto"})
                    self._add(sev, "nikto", entry)

    # ── 15. JS Endpoint Extraction ────────────────────────────────────────────
    def run_js_analysis(self, prog):
        prog.log(f"  [bold {C2}]js[/] → JavaScript endpoint + secret extraction ...")

        if tool_ok("katana"):
            prog.log(f"  [bold {C2}]katana[/] → JS-aware crawl ...")
            ok, out = run_cmd(["katana", "-u", self.base_url, "-silent", "-depth", "3",
                                "-js-crawl", "-known-files", "all", "-timeout", "10",
                                "-rate-limit", "20"], 120)
            if ok:
                for l in lns(out):
                    if re.search(r"\.js(\?|$)", l): self.results["js_endpoints"].append(l)
                    if re.search(r"api|endpoint|token|key|secret|password|passwd", l, re.I):
                        sev = classify_name(l)
                        if sev in ("HIGH","CRITICAL"): self._add(sev, "js-endpoint", l)

        # Analyse JS files for secrets
        SECRET_PATTERNS = {
            "AWS Access Key":    r"AKIA[0-9A-Z]{16}",
            "AWS Secret Key":    r"aws_secret_access_key\s*[=:]\s*[\"']?([A-Za-z0-9+/]{40})",
            "GitHub Token":      r"ghp_[A-Za-z0-9]{36}|github_token\s*[=:]\s*[\"']?[A-Za-z0-9_\-]{40}",
            "Slack Token":       r"xox[baprs]-[A-Za-z0-9\-]+",
            "Google API Key":    r"AIza[0-9A-Za-z\-_]{35}",
            "Stripe Secret Key": r"sk_live_[A-Za-z0-9]{24}",
            "Stripe Public Key": r"pk_live_[A-Za-z0-9]{24}",
            "JWT Token":         r"eyJ[A-Za-z0-9+/]{10,}\.[A-Za-z0-9+/]{10,}\.[A-Za-z0-9+/\-_]+",
            "Private Key PEM":   r"-----BEGIN (RSA |EC )?PRIVATE KEY-----",
            "DB Password":       r"db_password\s*[=:]\s*[\"']?(\S{6,})",
            "API Key Generic":   r"api[_\-]?key\s*[=:]\s*[\"']?([A-Za-z0-9\-_]{20,})",
            "Bearer Token":      r"bearer\s+[A-Za-z0-9\-_\.]{20,}",
        }
        for url in self.results["js_endpoints"][:20]:
            ok, body = run_cmd(["curl", "-s", "--max-time", "8", "--insecure", url], 12)
            if not ok: continue
            for name, pat in SECRET_PATTERNS.items():
                if re.search(pat, body, re.I):
                    self.results["secrets"].append(f"{name} in {url}")
                    self._add("CRITICAL", "secret-exposed", f"{name} found in JS: {url}")

    # ── 16. Open Redirect Check ───────────────────────────────────────────────
    def run_open_redirect(self, prog):
        prog.log(f"  [bold {C2}]redirect[/] → open redirect detection ...")
        redirect_params = ["url","redirect","next","return","returnUrl","return_url",
                           "continue","goto","dest","destination","redir","redirect_uri","callback"]
        payloads = ["//evil.com", "https://evil.com", "//evil.com/%2f.."]
        for param in redirect_params[:8]:
            for payload in payloads[:2]:
                url = f"{self.base_url}/?{param}={payload}"
                # Do NOT follow redirects (-L) — check raw Location header instead
                ok, out = run_cmd(["curl", "-s", "-o", "/dev/null",
                                   "-w", "%{redirect_url}",
                                   "--max-time", "5", "--connect-timeout", "3",
                                   "--insecure", "-D", "-", url], 10)
                if ok and "evil.com" in out.lower():
                    self._add("HIGH", "open-redirect",
                              f"Open redirect via ?{param}= — redirects to {payload}")
                    self.results["open_redirects"].append(f"?{param}= → {payload}")

    # ── MASTER RUNNER ─────────────────────────────────────────────────────────
    def run_all(self):
        steps = [
            ("Passive Subdomain Enumeration",    self.run_subdomains,     C2,    "◈"),
            ("DNS Records & Zone Transfer",      self.run_dns,            LBLUE, "◈"),
            ("ASN / IP / Whois",                 self.run_asn,            GREY,  "◈"),
            ("Live Host Detection",              self.run_live_hosts,     GREEN, "◈"),
            ("Technology Fingerprinting",        self.run_tech,           PURP,  "◈"),
            ("WAF / CDN / Firewall Detection",   self.run_waf,            GOLD,  "◈"),
            ("URL & Archive Harvesting",         self.run_urls,           C3,    "◈"),
            ("Port & Service Scanning",          self.run_ports,          ORNG,  "◈"),
            ("SSL/TLS Certificate Audit",        self.run_ssl,            TEAL,  "◈"),
            ("HTTP Security Header Audit",       self.run_header_audit,   PINK,  "◈"),
            ("Sensitive Path Discovery",         self.run_dirs,           RED,   "◈"),
            ("JavaScript & Secret Extraction",   self.run_js_analysis,    C1,    "◈"),
            ("XSS Parameter Scan",               self.run_xss,            RED,   "◈"),
            ("Open Redirect Detection",          self.run_open_redirect,  ORNG,  "◈"),
            ("Nuclei Vulnerability Scan",        self.run_nuclei,         RED,   "◈"),
            ("Nikto Web Scan",                   self.run_nikto,          RED,   "◈"),
        ]

        with Progress(
            SpinnerColumn(spinner_name="arc", style=f"bold {C1}"),
            TextColumn(f"[bold {WHITE}]{{task.description}}"),
            BarColumn(bar_width=26, style=C1, complete_style=GREEN, finished_style=GREEN),
            TaskProgressColumn(),
            TimeElapsedColumn(),
            console=console, transient=False,
        ) as prog:
            overall = prog.add_task(f"[bold {GOLD}]  ◈  Total Progress[/]", total=len(steps))
            for name, fn, col, icon in steps:
                task = prog.add_task(f"[bold {col}]{icon}[/]  {name}", total=None)
                try:
                    fn(prog)
                except KeyboardInterrupt:
                    prog.log(f"  [bold {ORNG}]⚡[/]  {name} interrupted by user")
                    break
                except Exception as e:
                    prog.log(f"  [bold {RED}]✘[/]  {name} error: {e}")
                prog.update(task, completed=1, total=1, description=f"[bold {GREEN}]✔[/]  {name}")
                prog.advance(overall)
                time.sleep(0.05)

