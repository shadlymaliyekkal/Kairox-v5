    api_items = [(tp,v) for sev in ("CRITICAL","HIGH","MEDIUM")
                 for tp,v in recon.findings[sev]
                 if tp in ("sensitive-url","interesting-url","js-endpoint","api_endpoint")]
    if api_items:
        section_header("API ENDPOINTS & INTERESTING URLS", PURP)
        for _, u in api_items[:40]:
            t = Text(); t.append("  ⬡  ", style=f"bold {PURP}"); t.append(u, style=f"bold {C2}")
            console.print(t)

    # ══ EMAILS ════════════════════════════════════════════════════════════════
    if recon.results["emails"]:
        section_header(f"EMAIL ADDRESSES  ({len(recon.results['emails'])} found)", LIME)
        for e in recon.results["emails"][:25]:
            t = Text(); t.append("  @  ", style=f"bold {LIME}"); t.append(e, style=f"bold {C2}")
            console.print(t)

    # ══ PARAMETERS ════════════════════════════════════════════════════════════
    if recon.results["parameters"]:
        section_header(f"DISCOVERED PARAMETERS  ({len(recon.results['parameters'])} unique)", C3)
        params_txt = "  " + "   ".join(recon.results["parameters"][:60])
        console.print(Text(params_txt, style=f"bold {C3}"))
        console.print()
        if len(recon.results["parameters"]) > 60:
            console.print(f"  [dim {GREY}]  + {len(recon.results['parameters'])-60} more in JSON report[/]")

    # ══ FOOTER ════════════════════════════════════════════════════════════════
    console.print()
    console.print(Rule(style=f"bold {TEAL}", characters="━"))
    footer = Text()
    footer.append("  KAIROX v5  ", style=f"bold {C1}")
    footer.append("◈", style=f"bold {GOLD}")
    footer.append("  by Shadly Maliyekkal  ", style=f"bold {PURP}")
    footer.append("◈", style=f"bold {GOLD}")
    footer.append("  Elite Recon + Vulnerability Platform  ", style=f"dim {GREY}")
    footer.append("◈", style=f"bold {GOLD}")
    footer.append("  Authorized use only  ", style=f"dim {GREY}")
    console.print(Align.center(footer))
    console.print(Rule(style=f"bold {TEAL}", characters="━"))
    console.print()

    save_report(recon)

