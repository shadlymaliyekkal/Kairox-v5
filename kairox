#   SAVE JSON REPORT
# ══════════════════════════════════════════════════════════════════════════════

def save_report(recon):
    ts = recon.start_ts.strftime("%Y%m%d_%H%M%S")
    fname = f"kairox_v5_{recon.target.replace('.','_')}_{ts}.json"
    dirs_out = [{"path": e, "severity": sev, "status_code": c} for e, sev, c in recon.results["dirs"]]
    data = {
        "tool": "KAIROX v5",
        "target": recon.target,
        "timestamp": recon.start_ts.isoformat(),
        "duration_seconds": (datetime.now()-recon.start_ts).total_seconds(),
        "severity_guide": {
            "CRITICAL": "RCE/Auth-bypass CVEs, exposed secrets/credentials",
            "HIGH": "HTTP 200/301 on sensitive paths, severe CVEs, dangerous ports",
            "MEDIUM": "403/401 protected paths, misconfigurations",
            "LOW": "Information disclosure, missing security headers",
            "INFO": "Passive data — DNS, ASN, technologies",
        },
        "results": {
            "subdomains":  recon.results["subdomains"],
            "live_hosts":  recon.results["live_hosts"],
            "urls":        recon.results["urls"][:2000],
            "ports":       recon.results["ports"],
            "dirs":        dirs_out,
            "waf":         recon.results["waf"],
            "vulns":       recon.results["vulns"],
            "ssl":         recon.results["ssl"],
            "dns":         recon.results["dns"],
            "tech":        recon.results["tech"],
            "emails":      recon.results["emails"],
            "asn":         recon.results["asn"],
            "js_endpoints":recon.results["js_endpoints"],
            "secrets":     recon.results["secrets"],
            "cors_issues": recon.results["cors_issues"],
            "open_redirects": recon.results["open_redirects"],
            "parameters":  recon.results["parameters"],
        },
        "findings": {s: list(items) for s, items in recon.findings.items()},
        "statistics": {
            "total_findings": sum(len(v) for v in recon.findings.values()),
            "critical": len(recon.findings["CRITICAL"]),
            "high":     len(recon.findings["HIGH"]),
            "medium":   len(recon.findings["MEDIUM"]),
            "low":      len(recon.findings["LOW"]),
            "info":     len(recon.findings["INFO"]),
        }
    }
    try:
        Path(fname).write_text(json.dumps(data, indent=2, default=str))
        t = Text()
        t.append("  ✔  ", style=f"bold {GREEN}")
        t.append("Report saved  →  ", style=f"dim {GREY}")
        t.append(fname, style=f"bold {C1}")
        console.print(t); console.print()
    except Exception as e:
        console.print(f"  [bold {RED}]⚠[/]  Could not save report: {e}")

