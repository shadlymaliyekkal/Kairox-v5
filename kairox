def animate_banner():
    os.system("clear 2>/dev/null || cls 2>/dev/null")
    n = len(BANNER)

    # Phase 1: Matrix rain build-up
    for fr in range(35):
        prog = fr / 34
        lines = []
        for i, line in enumerate(BANNER):
            lr = min(1.0, max(0.0, prog * 1.8 - i * 0.08))
            chars = []
            for j, ch in enumerate(line):
                cr = j / max(len(line)-1, 1)
                if   lr > cr + 0.06: chars.append(ch)
                elif lr > cr:        chars.append(random.choice(GLITCH_CHARS))
                else:
                    if random.random() < lr * 0.85:
                        chars.append(random.choice(MATRIX_CHARS))
                    else:
                        chars.append(" ")
            lines.append(Text("".join(chars), style=LGRAD[i]))
        console.print()
        for l in lines: _center_print(l)
        time.sleep(0.025)
        sys.stdout.write(f"\033[{n+1}A"); sys.stdout.flush()

    # Phase 2: Glitch storm
    GCOLS = ["color(201)","color(51)","color(226)","color(196)","color(135)","color(82)"]
    for g in range(8):
        lines = []
        for i, line in enumerate(BANNER):
            if g < 5 and random.random() < 0.55:
                col = random.choice(GCOLS)
                gl = "".join(random.choice(GLITCH_CHARS) if random.random() < 0.25 else c for c in line)
                lines.append(Text(gl, style=f"bold {col}"))
            else:
                lines.append(Text(line, style=f"bold {LGRAD[i]}"))
        console.print()
        for l in lines: _center_print(l)
        time.sleep(0.045)
        sys.stdout.write(f"\033[{n+1}A"); sys.stdout.flush()

    # Phase 3: Scanline sweep
    for fr in range(24):
        sp = fr / 23
        lines = []
        for i, line in enumerate(BANNER):
            t = Text()
            for j, ch in enumerate(line):
                d = abs(j / max(len(line)-1, 1) - sp)
                if   d < 0.05: t.append(ch, style="bold color(255)")
                elif d < 0.12: t.append(ch, style=f"bold {C1}")
