                                        self.results["dirs"].append(result)
                                if sev in ("CRITICAL","HIGH","MEDIUM"):
                                    self._add(sev, "sensitive-path", entry)
                        except Exception:
                            pass
                except Exception:
                    pass  # overall timeout — partial results kept

