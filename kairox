#   NUCLEI RESOURCE GUARD — prevents CPU/memory spike crash
# ══════════════════════════════════════════════════════════════════════════════

# ── RAM limit in MB for nuclei child process ─────────────────────────────────
_NUCLEI_RAM_LIMIT_BYTES = 400 * 1024 * 1024   # 400 MB hard cap

def _nuclei_preexec():
    """Called in the child process after fork() — before nuclei starts.
    Sets CPU nice level and virtual-memory cap so it cannot spike Kali."""
    try:
        os.nice(15)   # low priority — won't starve other processes
    except Exception:
        pass
    try:
        # Cap virtual address space to 400 MB — nuclei dies cleanly if exceeded
        resource.setrlimit(resource.RLIMIT_AS,
                           (_NUCLEI_RAM_LIMIT_BYTES, _NUCLEI_RAM_LIMIT_BYTES))
    except Exception:
        pass


class NucleiGuard:
    """Wraps every nuclei execution with:
       • nice +15  (low CPU priority)
       • RLIMIT_AS 400 MB  (hard RAM cap — nuclei killed by OS if exceeded)
       • Wall-clock deadline watchdog thread
       • RAM polling watchdog thread (using psutil if available)
       • Strict rate-limit / concurrency / timeout flags
    """
    WALL_TIMEOUT = 90    # seconds per phase before SIGTERM
    RATE_LIMIT   = 10    # requests/sec  (was 15 — reduced)
    CONCURRENCY  = 5     # parallel goroutines  (was 10 — reduced)
    TIMEOUT_SEC  = 7     # per-request HTTP timeout
    BULK_SIZE    = 5     # templates per bulk batch

    @staticmethod
    def _build_cmd(target, tags, severity):
        return [
            "nuclei",
            "-u",           target,
            "-silent",
            "-no-color",
            "-severity",    severity,
            "-rate-limit",  str(NucleiGuard.RATE_LIMIT),
            "-c",           str(NucleiGuard.CONCURRENCY),
            "-timeout",     str(NucleiGuard.TIMEOUT_SEC),
            "-bulk-size",   str(NucleiGuard.BULK_SIZE),
            "-retries",     "0",
            "-tags",        tags,
        ]

    @staticmethod
    def run_phase(target, tags, severity, wall_timeout=None):
        """Run one nuclei phase. Returns (ok: bool, lines: list[str]).
        Guaranteed to return — never hangs or crashes the parent."""
        if wall_timeout is None:
            wall_timeout = NucleiGuard.WALL_TIMEOUT

        cmd = NucleiGuard._build_cmd(target, tags, severity)
        out_lines = []
        proc = None

        def _kill(reason):
            if proc is None:
                return
            try:
                os.killpg(os.getpgid(proc.pid), signal.SIGTERM)
            except Exception:
                pass
            try:
                proc.terminate()
            except Exception:
                pass
            out_lines.append(f"[kx-guard] nuclei stopped: {reason}")

        def _ram_watchdog():
            """Poll RAM every 3 s; kill if nuclei exceeds 350 MB RSS."""
            try:
                import psutil
                p = psutil.Process(proc.pid)
                while proc.poll() is None:
                    time.sleep(3)
                    try:
                        rss = p.memory_info().rss
                        if rss > 350 * 1024 * 1024:
                            _kill(f"RAM limit exceeded ({rss//1024//1024} MB)")
                            return
                    except Exception:
                        return
            except Exception:
                pass  # psutil not available — RLIMIT_AS handles it instead

        try:
            proc = subprocess.Popen(
                cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
                preexec_fn=_nuclei_preexec,   # nice + RLIMIT_AS set in child
            )
        except FileNotFoundError:
            return False, ["[nuclei not found]"]
        except Exception as e:
            return False, [f"[nuclei launch error: {e}]"]

        # Start RAM watchdog in background thread
        ram_thread = threading.Thread(target=_ram_watchdog, daemon=True)
        ram_thread.start()

        deadline = time.time() + wall_timeout
        try:
            while True:
                # Use readline with a short timeout via select
                ready = select.select([proc.stdout], [], [], 0.5)
                if ready[0]:
                    line = proc.stdout.readline()
                    if line:
                        stripped = line.strip()
                        if stripped:
                            out_lines.append(stripped)
                    elif proc.poll() is not None:
                        break  # EOF + process exited
                else:
                    if proc.poll() is not None:
                        break  # process exited, stdout drained
                if time.time() > deadline:
                    _kill("wall-time limit reached")
                    break
        except Exception:
            _kill("read error")

        # Give process 4 s to exit cleanly after kill signal
        try:
            proc.wait(timeout=4)
        except Exception:
            try:
                proc.kill()
            except Exception:
                pass

        return True, out_lines


