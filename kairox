class KairoxV5:
    def __init__(self, target):
        raw = target.strip().lower()
        raw = re.sub(r'^https?://', '', raw).rstrip('/')
        self.target   = raw
        self.base_url = f"https://{self.target}"
        self.start_ts = datetime.now()
        self.results  = {
            "subdomains":[], "live_hosts":[], "urls":[], "ports":[],
            "dirs":[], "waf":[], "vulns":[], "ssl":[], "dns":[],
            "tech":[], "emails":[], "asn":[], "js_endpoints":[],
            "open_redirects":[], "cors_issues":[], "api_endpoints":[],
            "parameters":[], "secrets":[], "screenshots":[],
        }
        self.findings = {"CRITICAL":[], "HIGH":[], "MEDIUM":[], "LOW":[], "INFO":[]}
        self._lock    = threading.Lock()

    def _add(self, sev, ftype, value):
        sev = sev if sev in self.findings else "INFO"
        with self._lock:
            entry = (ftype, value)
            if entry not in self.findings[sev]:
                self.findings[sev].append(entry)

    # ── 1. Passive Subdomain Enumeration ─────────────────────────────────────
    def run_subdomains(self, prog):
        subs = set()

        if tool_ok("subfinder"):
            prog.log(f"  [bold {C2}]subfinder[/] → passive subdomain enum ...")
            ok, out = run_cmd(["subfinder", "-d", self.target, "-all", "-recursive", "-silent"], 180)
            if ok:
                for s in lns(out): subs.add(s.lower())

        if tool_ok("assetfinder"):
            prog.log(f"  [bold {C2}]assetfinder[/] → quick subdomain find ...")
            ok, out = run_cmd(["assetfinder", "--subs-only", self.target], 60)
            if ok:
                for s in lns(out):
                    if self.target in s: subs.add(s.lower())

        if tool_ok("amass"):
            prog.log(f"  [bold {C2}]amass[/] → OSINT passive enum ...")
            ok, out = run_cmd(["amass", "enum", "-passive", "-d", self.target], 240)
            if ok:
                for s in lns(out): subs.add(s.lower())

        if tool_ok("dnsx") and subs:
            prog.log(f"  [bold {C2}]dnsx[/] → resolving + permutation ...")
            inp = "\n".join(subs)
            try:
                r = subprocess.run(["dnsx", "-silent", "-resp", "-a", "-aaaa", "-cname"],
                                   input=inp, capture_output=True, text=True, timeout=60)
                for l in lns(r.stdout):
                    s = l.split()[0].lower()
                    if self.target in s: subs.add(s)
            except: pass

        # Certificate transparency (passive, no tools needed)
        prog.log(f"  [bold {C2}]crt.sh[/] → certificate transparency logs ...")
        try:
            ok_crt, crt_out = run_cmd(
                ["curl", "-s", "--max-time", "15", "--insecure",
                 f"https://crt.sh/?q=%.{self.target}&output=json"], 20)
            if ok_crt and crt_out:
                for m in re.finditer(r'"name_value"\s*:\s*"([^"]+)"', crt_out):
                    for s in m.group(1).split('\n'):
                        s = s.strip().lower().lstrip('*.')
                        if self.target in s and s: subs.add(s)
        except Exception: pass

        # HackerTarget API
        prog.log(f"  [bold {C2}]hackertarget[/] → passive subdomain lookup ...")
        ok, out = run_cmd(["curl", "-s", f"https://api.hackertarget.com/hostsearch/?q={self.target}"], 15)
        if ok:
            for l in lns(out):
                parts = l.split(",")
                if parts and self.target in parts[0]: subs.add(parts[0].strip().lower())

        # DNS wordlist fallback
        if not subs:
            prog.log(f"  [bold {ORNG}]fallback[/] → DNS wordlist probe ...")
            wl = ["www","mail","ftp","dev","staging","api","app","test","admin","vpn",
                  "remote","beta","portal","shop","blog","m","mobile","ns1","ns2",
                  "smtp","webmail","cdn","static","assets","media","img","data",
                  "auth","login","secure","cloud","office","store","help","support",
                  "prod","qa","uat","demo","sandbox","monitor","dashboard","status",
                  "internal","intranet","corp","wiki","docs","git","svn","jenkins"]
            for w in wl:
                h = f"{w}.{self.target}"
                try: socket.gethostbyname(h); subs.add(h)
                except: pass

        self.results["subdomains"] = sorted(subs)
        for s in self.results["subdomains"]:
            sev = classify_name(s)
            if sev in ("HIGH","CRITICAL"): self._add(sev, "subdomain", s)
            else: self._add("INFO", "subdomain", s)

    # ── 2. DNS Records & Zone Transfer ───────────────────────────────────────
    def run_dns(self, prog):
        prog.log(f"  [bold {C2}]dns[/] → extracting all DNS record types ...")
        records = []
        for rtype in ["A", "AAAA", "MX", "TXT", "NS", "CNAME", "SOA", "PTR", "SRV", "CAA"]:
            ok, out = run_cmd(["dig", "+short", rtype, self.target], 15)
            if ok and out:
                for l in lns(out):
                    records.append(f"{rtype:<8} {l}")
                    if rtype == "TXT":
                        if "v=spf1" in l.lower():
                            self._add("INFO", "spf", l)
                            if "+all" in l.lower():
                                self._add("MEDIUM", "weak-spf", f"SPF uses +all — anyone can send as {self.target}")
                        if "v=dmarc1" in l.lower():
                            self._add("INFO", "dmarc", l)
                            if "p=none" in l.lower():
                                self._add("MEDIUM", "weak-dmarc", f"DMARC policy=none — no enforcement, email spoofing possible")
                    if rtype == "MX": self._add("INFO", "mx", l)

        # AXFR zone transfer attempt
        prog.log(f"  [bold {C2}]dns[/] → zone transfer attempt (AXFR) ...")
        ok, out = run_cmd(["dig", "AXFR", self.target, f"@ns1.{self.target}"], 12)
        if ok and "Transfer failed" not in out and len(out) > 100:
            self._add("HIGH", "zone-transfer", f"DNS AXFR zone transfer SUCCEEDED on {self.target}")
            records.append(f"AXFR     TRANSFER SUCCEEDED — full zone exposed!")
        else:
            # Try other nameservers
            ns_ok, ns_out = run_cmd(["dig", "+short", "NS", self.target], 10)
            if ns_ok:
                for ns in lns(ns_out)[:3]:
                    ok2, out2 = run_cmd(["dig", "AXFR", self.target, f"@{ns}"], 12)
                    if ok2 and len(out2) > 100 and "Transfer failed" not in out2:
                        self._add("HIGH", "zone-transfer", f"AXFR transfer succeeded via {ns}")
                        records.append(f"AXFR     SUCCEEDED via {ns}")
                        break

        self.results["dns"] = records

    # ── 3. ASN / IP / Whois ───────────────────────────────────────────────────
    def run_asn(self, prog):
        prog.log(f"  [bold {C2}]asn[/] → IP resolution + ASN + CIDR ...")
        try:
            ip = socket.gethostbyname(self.target)
            self.results["asn"].append(f"Resolved IP    {ip}")
            ok, out = run_cmd(["whois", ip], 20)
            if ok:
                for kw in ["OrgName","org-name","netname","country","CIDR","route","descr","NetRange","inetnum"]:
                    for l in lns(out):
                        if l.lower().startswith(kw.lower()+":"):
                            self.results["asn"].append(l.strip())
            # Check if IP is in cloud range → bypass hint
            cloud_ranges = {"AWS":["54.","52.","34.","35.","18.","3."],
                            "Google":["34.","35.","104.","130.211."],
                            "Azure":["40.","20.","13.","52."],
                            "Cloudflare":["104.16.","104.17.","104.18.","104.19.","172.64.","172.65."]}
            for cloud, prefixes in cloud_ranges.items():
                for pfx in prefixes:
                    if ip.startswith(pfx):
                        self.results["asn"].append(f"Cloud Host     Likely {cloud}")
                        self._add("INFO", "cloud-hosting", f"{self.target} resolves to {cloud} IP range ({ip})")
                        break
        except Exception as e:
            self.results["asn"].append(f"DNS resolution failed: {e}")

    # ── 4. Live Host Detection ────────────────────────────────────────────────
    def run_live_hosts(self, prog):
        hosts = []
        inputs = self.results["subdomains"] or [self.target]
        if tool_ok("httpx"):
            prog.log(f"  [bold {C2}]httpx[/] → probing {len(inputs)} hosts ...")
            try:
                r = subprocess.run(
                    ["httpx", "-silent", "-status-code", "-title", "-tech-detect",
                     "-server", "-no-color", "-follow-redirects", "-rate-limit", "50"],
                    input="\n".join(inputs), capture_output=True, text=True, timeout=180)
                for line in lns(r.stdout):
                    hosts.append(line)
                    m = re.search(r"\[(\d{3})\]", line)
                    code = m.group(1) if m else "200"
                    self._add(classify_path_with_status(line, code), "live_host", line)
            except Exception as e:
                prog.log(f"  [bold {RED}]httpx error[/]: {e}")
        else:
            prog.log(f"  [bold {ORNG}]fallback[/] → curl HTTP probe ...")
            for h in inputs[:25]:
                for scheme in ("https", "http"):
                    url = f"{scheme}://{h}"
                    ok, code = run_cmd(["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
                                        "-L", "--max-time", "5", "--connect-timeout", "3", "--insecure", url], 10)
                    if ok and code.strip() in ("200","301","302","403","401"):
                        entry = f"{url}  [{code.strip()}  {status_tag(code.strip())}]"
                        hosts.append(entry)
                        self._add(classify_path_with_status(url, code), "live_host", entry)
                        break
        self.results["live_hosts"] = hosts

