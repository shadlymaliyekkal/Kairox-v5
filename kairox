def classify_name(text):
    t = text.lower()
    for p in CRITICAL_PATHS:
        if re.search(p, t): return "CRITICAL"
    for p in HIGH_PATHS:
        if re.search(p, t): return "HIGH"
    for p in MEDIUM_PATHS:
        if re.search(p, t): return "MEDIUM"
    return "LOW"

def classify_path_with_status(url, code):
    c = str(code).strip()
    base_sev = classify_name(url)
    if c in ("200","201","301","302"):
        return base_sev if base_sev != "LOW" else "MEDIUM"
    elif c in ("401",):   return "MEDIUM"
    elif c in ("403",):   return "LOW"
    return "INFO"

def status_tag(code):
    return {
        "200":"OPEN","201":"CREATED","301":"REDIRECT","302":"REDIRECT",
        "401":"AUTH-REQUIRED","403":"FIREWALL/BLOCKED","404":"NOT-FOUND",
        "500":"SERVER-ERROR","503":"UNAVAILABLE"
    }.get(str(code).strip(), str(code).strip())

