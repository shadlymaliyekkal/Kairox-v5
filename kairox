                        self._add(sev, "cve-banner", entry)

            # UDP scan for key services
            prog.log(f"  [bold {C2}]nmap[/] → UDP probe (SNMP/DNS/NTP/TFTP) ...")
            ok2, out2 = run_cmd(["nmap", "-sU", "-Pn", "--open", "-T3", "-p", "53,67,68,69,123,161,162,500,514,1194,4500", self.target], 90)
            if ok2:
                for l in lns(out2):
                    if "open" in l.lower() and re.search(r"\d+/udp", l):
                        self.results["ports"].append(f"UDP: {l}")
                        if "161" in l: self._add("HIGH", "snmp-open", f"SNMP UDP 161 open — community string brute possible")
