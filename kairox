    # ── 6. WAF Detection ──────────────────────────────────────────────────────
    def run_waf(self, prog):
        prog.log(f"  [bold {C2}]waf[/] → fingerprinting WAF/CDN/firewall ...")
        waf_results = []

        if tool_ok("wafw00f"):
            prog.log(f"  [bold {C2}]wafw00f[/] → automated WAF detection ...")
            ok, out = run_cmd(["wafw00f", self.base_url, "-a"], 35)
            if ok:
                for l in lns(out):
                    if re.search(r"is behind|detected|firewall|WAF", l, re.I):
                        waf_results.append(l.strip())

        # Passive fingerprint from multiple probe responses
        h1, b1, c1 = curl_get(self.base_url)
        h2, b2, c2 = curl_get(f"{self.base_url}/?id=1'<script>alert(1)</script>--", timeout=8)
        h3, b3, c3 = curl_get(f"{self.base_url}/?cmd=../../../../etc/passwd", timeout=8)

        all_headers = (h1+h2+h3).lower()
        all_body    = (b1+b2+b3).lower()
        cookies     = " ".join(re.findall(r"set-cookie:\s*([^\r\n;]+)", all_headers, re.I))

        detected = fingerprint_waf(all_headers, all_body, cookies)
        for waf_name, conf, score in detected:
            entry = {
                "name": waf_name, "confidence": conf, "score": score,
                "weaknesses": WAF_DB[waf_name]["weaknesses"],
                "bypass_notes": WAF_DB[waf_name].get("bypass_notes", ""),
            }
            self.results["waf"].append(entry)
            sev = "MEDIUM" if conf in ("HIGH","MEDIUM") else "INFO"
            self._add(sev, "waf-detected", f"{waf_name} (confidence: {conf})")

        if not self.results["waf"]:
            self.results["waf"].append({
                "name": "None/Unknown", "confidence": "LOW", "score": 0,
                "weaknesses": ["No WAF fingerprint matched — target may be unprotected"],
                "bypass_notes": "No WAF detected — test directly without bypass techniques",
            })
            self._add("MEDIUM", "no-waf", "No WAF detected — target appears unprotected")

