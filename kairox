def main():
    # Signal handling for clean exit
    def sigint_handler(sig, frame):
        console.print(f"\n\n  [bold {ORNG}]⚡[/]  Interrupted. Exiting cleanly.\n")
        sys.exit(0)
    signal.signal(signal.SIGINT, sigint_handler)

    animate_banner()
    boot_sequence()
    show_disclaimer()
    require_consent()
    check_tools()

    console.print(f"  [bold {GOLD}]◈[/]  [bold {WHITE}]Enter target domain[/]  [dim {GREY}](e.g. example.com — no http://)[/]")
    target = Prompt.ask(f"  [bold {C1}]  ❯[/]").strip()

    target = re.sub(r'^https?://', '', target).rstrip('/').strip()
    if not target or '.' not in target:
        console.print(f"\n  [bold {RED}]✘[/]  Invalid domain. Exiting.\n")
        sys.exit(1)

    console.print()
    scan_init_anim(target)

    console.print(Panel(
        f"  [bold {TEAL}]Target   [/]  [bold {C1}]{target}[/]\n"
        f"  [bold {TEAL}]Mode     [/]  Elite Active + Passive Recon + Vulnerability Detection\n"
        f"  [bold {TEAL}]Modules  [/]  Subdomain · DNS · AXFR · ASN · Ports · UDP · SSL · WAF\n"
        f"           Headers · Paths · JS · XSS · Redirect · Nuclei · Nikto\n"
        f"  [bold {TEAL}]Engine   [/]  [bold {C1}]KAIROX v5[/]  ·  Nuclei resource-guarded  ·  by Shadly Maliyekkal",
        title=f"[bold {GOLD}]  ◈  SCAN INITIALIZING  ◈  [/]",
        border_style=GOLD, box=box.DOUBLE_EDGE, expand=False))
    console.print()

    recon = KairoxV5(target)
    recon.run_all()
    render_results(recon)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        console.print(f"\n\n  [bold {ORNG}]⚡[/]  Interrupted. Exiting cleanly.\n")
        sys.exit(0)
