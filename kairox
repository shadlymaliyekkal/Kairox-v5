            common = [21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443,9200,27017]
            for port in common:
                try:
                    s = socket.socket(); s.settimeout(1.5); s.connect((self.target, port)); s.close()
                    entry = f"{port}/tcp open"
                    self.results["ports"].append(entry)
                    self._add(classify_name(entry), "port", entry)
                except: pass

    # ── 9. SSL/TLS Audit ──────────────────────────────────────────────────────
    def run_ssl(self, prog):
        prog.log(f"  [bold {C2}]ssl[/] → comprehensive SSL/TLS analysis ...")
        findings = []
        raw = ""

        if tool_ok("testssl.sh") or os.path.isfile("/usr/local/bin/testssl.sh"):
            tssl = "testssl.sh" if tool_ok("testssl.sh") else "/usr/local/bin/testssl.sh"
            prog.log(f"  [bold {C2}]testssl.sh[/] → deep TLS audit ...")
            ok, out = run_cmd([tssl, "--quiet", "--color", "0", "--fast", self.target], 120)
            if ok: raw = out
        elif tool_ok("sslscan"):
            prog.log(f"  [bold {C2}]sslscan[/] → TLS audit ...")
            ok, out = run_cmd(["sslscan", "--no-colour", self.target], 60)
            if ok: raw = out

        if raw:
            for name, sev, pat, desc in SSL_VULNS:
                if re.search(pat, raw, re.I):
                    findings.append({"check": name, "sev": sev, "desc": desc})
                    self._add(sev, "ssl", f"{name}: {desc}")

        # OpenSSL cert inspection
        prog.log(f"  [bold {C2}]openssl[/] → certificate inspection ...")
        try:
            p1 = subprocess.Popen(
                ["openssl", "s_client", "-connect", f"{self.target}:443",
                 "-servername", self.target],
                stdin=subprocess.DEVNULL, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
            p2 = subprocess.Popen(
                ["openssl", "x509", "-noout", "-dates", "-subject", "-issuer", "-fingerprint"],
                stdin=p1.stdout, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
            p1.stdout.close()
            cert_info, _ = p2.communicate(timeout=15)
            cert_str = cert_info.decode("utf-8", "ignore")
            if cert_str:
                findings.append({"check": "Certificate Details", "sev": "INFO", "desc": cert_str.strip()})
                # Parse expiry
                m = re.search(r"notAfter=(.+)", cert_str)
                if m:
                    try:
                        exp = datetime.strptime(m.group(1).strip(), "%b %d %H:%M:%S %Y %Z")
                        days = (exp - datetime.utcnow()).days
                        if days < 0:
                            self._add("HIGH", "cert-expired", f"Certificate EXPIRED {abs(days)} days ago")
                        elif days < 30:
                            self._add("MEDIUM", "cert-expiring", f"Certificate expires in {days} days")
                        else:
                            self._add("INFO", "cert-valid", f"Certificate valid for {days} more days")
                    except: pass
                # Check for wildcard cert (info)
                if "*."+self.target in cert_str:
                    self._add("INFO", "wildcard-cert", f"Wildcard certificate for *.{self.target}")
        except: pass

        self.results["ssl"] = findings

    # ── 10. HTTP Security Header Audit ───────────────────────────────────────
    def run_header_audit(self, prog):
        prog.log(f"  [bold {C2}]headers[/] → security header analysis ...")
        headers, body, code = curl_get(self.base_url)
        h = headers.lower()

        missing_headers = {
            "strict-transport-security":  ("HSTS Not Set",                  "MEDIUM", "HTTP downgrade / MITM possible"),
            "x-frame-options":            ("X-Frame-Options Missing",        "MEDIUM", "Clickjacking attack possible"),
            "x-content-type-options":     ("X-Content-Type-Options Missing", "LOW",    "MIME sniffing enabled"),
            "content-security-policy":    ("Content-Security-Policy Missing","MEDIUM", "XSS amplified without CSP"),
            "referrer-policy":            ("Referrer-Policy Missing",        "LOW",    "URL data leaks via Referer"),
            "permissions-policy":         ("Permissions-Policy Missing",     "LOW",    "Browser features not restricted"),
        }
        for hdr, (name, sev, desc) in missing_headers.items():
            if hdr not in h:
                self.results["vulns"].append({"check":name,"sev":sev,"desc":desc,"source":"headers"})
                self._add(sev, "missing-header", f"{name}: {desc}")

        info_disclosure = {
            r"server:\s*(\S.+)":               ("Server Banner Disclosure",   "LOW"),
            r"x-powered-by:\s*(.+)":           ("X-Powered-By Disclosed",    "MEDIUM"),
            r"x-aspnet-version:\s*(.+)":       ("ASP.NET Version Exposed",   "MEDIUM"),
            r"x-aspnetmvc-version:\s*(.+)":    ("ASP.NET MVC Version",       "MEDIUM"),
            r"x-generator:\s*(.+)":            ("X-Generator Exposed",       "LOW"),
            r"x-runtime:\s*(.+)":              ("Rails X-Runtime Exposed",   "LOW"),
            r"x-debug-token:\s*(.+)":          ("Symfony Debug Token",       "HIGH"),
            r"x-amz-request-id:\s*(.+)":       ("AWS Request ID Exposed",    "LOW"),
        }
        for pat, (name, sev) in info_disclosure.items():
            m = re.search(pat, h)
            if m:
                val = m.group(1).strip()[:100]
                self.results["vulns"].append({"check":name,"sev":sev,"desc":val,"source":"headers"})
                self._add(sev, "info-disclosure", f"{name}: {val}")

        # CORS check
        prog.log(f"  [bold {C2}]cors[/] → CORS policy analysis ...")
        h2, b2, _ = curl_get(self.base_url,
                              extra_args=["-H", "Origin: https://evil.attacker.com"])
        if "access-control-allow-origin: https://evil.attacker.com" in h2.lower():
            self._add("HIGH", "cors-wildcard", f"CORS reflects arbitrary Origin — credential theft possible")
            self.results["cors_issues"].append("Origin reflection: evil.attacker.com accepted")
        elif "access-control-allow-origin: *" in h2.lower() and "access-control-allow-credentials: true" in h2.lower():
            self._add("HIGH", "cors-wildcard", "CORS wildcard + credentials=true — critical misconfiguration")
            self.results["cors_issues"].append("Wildcard CORS with credentials=true")

        # CVE correlation from banners
        combined = (headers + body).lower()
        for cve_id, sev, pat, desc, fix in CVE_DB:
            if re.search(pat, combined, re.I):
                entry = f"{cve_id} — {desc}"
                self.results["vulns"].append({"cve":cve_id,"sev":sev,"desc":desc,"fix":fix,"source":"header-cve"})
                self._add(sev, "cve-banner", entry)

        # Check for debug/error info
        if re.search(r"debug|stacktrace|exception.*at\s+[\w.]+\(", body, re.I):
            self._add("MEDIUM", "debug-info", "Application debug/stack trace visible in response body")
        if re.search(r"sql\s+syntax|mysql.*error|ORA-\d+|pg_query|PDOException", body, re.I):
            self._add("HIGH", "sql-error", "SQL error message exposed in HTTP response")

